datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client"
  output   = "../generated/client"
}

model User {
  id           String            @id @default(uuid())
  username     String            @unique
  passwordHash String
  name         String
  role         String            // 'ADMIN' | 'CASHIER'
  active       Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  sales        Sale[]
  expenses     Expense[]
  transfers    ProductTransfer[]
}

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
}

model Product {
  id             String            @id @default(uuid())
  sku            String            @unique
  name           String
  description    String?
  price          Float
  cost           Float
  stock          Int               @default(0)
  categoryId     String
  category       Category          @relation(fields: [categoryId], references: [id])
  department     String            // 'MARKET' | 'CAFE'
  isRawMaterial  Boolean           @default(false)
  active         Boolean           @default(true)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  saleItems      SaleItem[]
  expenseItems   ExpenseItem[]
  transfersFrom  ProductTransfer[] @relation("TransferSource")
  transfersTo    ProductTransfer[] @relation("TransferTarget")
}

model Expense {
  id          String        @id @default(uuid())
  description String
  amount      Float
  category    String        @default("supplies") // 'rent', 'utilities', 'supplies', 'INTERNAL_TRANSFER'
  department  String        @default("GENERAL")  // 'MARKET', 'CAFE', 'GENERAL'
  userId      String?
  user        User?         @relation(fields: [userId], references: [id])
  date        DateTime      @default(now())
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  items       ExpenseItem[]
}

model ExpenseItem {
  id        String  @id @default(uuid())
  expenseId String
  expense   Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  unitCost  Float
}

model Sale {
  id             String        @id @default(uuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id])
  total          Float
  status         String        @default("COMPLETED") // 'COMPLETED', 'CANCELLED', 'TRANSFER_OUT', 'OPEN'
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  items          SaleItem[]
  payments       SalePayment[]
  tableId        String?
  table          CafeTable?    @relation("TableSales", fields: [tableId], references: [id])
  activeForTable CafeTable?    @relation("TableActiveSale")
}

model SaleItem {
  id        String  @id @default(uuid())
  saleId    String
  sale      Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float
}

model SalePayment {
  id        String   @id @default(uuid())
  saleId    String
  sale      Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  method    String   // 'CASH', 'CARD', 'TRANSFER', 'INTERNAL'
  amount    Float
  createdAt DateTime @default(now())
}

model ProductTransfer {
  id              String   @id @default(uuid())
  productId       String
  product         Product  @relation("TransferSource", fields: [productId], references: [id])
  targetProductId String?
  targetProduct   Product? @relation("TransferTarget", fields: [targetProductId], references: [id])
  quantity        Int
  unitCost        Float
  totalCost       Float
  fromDepartment  String   // 'MARKET' | 'CAFE'
  toDepartment    String   // 'MARKET' | 'CAFE'
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  createdAt       DateTime @default(now())
}

model CafeTable {
  id             String    @id @default(uuid())
  name           String    @unique
  status         String    @default("AVAILABLE") // 'AVAILABLE', 'OCCUPIED'
  currentSaleId  String?   @unique
  currentSale    Sale?     @relation("TableActiveSale", fields: [currentSaleId], references: [id], onDelete: SetNull)
  sales          Sale[]    @relation("TableSales")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}
